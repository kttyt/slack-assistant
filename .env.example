# ── Авторизация Slack (сессия веб-клиента) ───────────────────────────────────
# Как получить — см. README.md (раздел "Получение токенов").
# Токен веб-клиента, начинается с "xoxc-"
SLACK_XOXC_TOKEN=xoxc-...
# Значение cookie "d", начинается с "xoxd-"
SLACK_XOXD_COOKIE=xoxd-...

# ── Расписание рабочих часов ─────────────────────────────────────────────────
# Таймзона (IANA), в которой считаются рабочие часы
TZ=Europe/Moscow
# Дни недели, когда держим зелёный: 1=пн ... 7=вс. Диапазоны и списки: "1-5" или "1,2,3,4,5"
WORK_DAYS=1-5
# Начало и конец рабочего окна в формате HH:MM (по TZ выше)
WORK_START=09:00
WORK_END=19:00
# Плавающее расписание: границы старта/конца каждый день случайно сдвигаются на
# модуль jitterMin..jitterMax минут (знак тоже случаен). Сдвиг детерминирован по дню
# (стабилен в течение суток, меняется день ото дня). 0/0 — выключить плавание.
JITTER_MIN_MINUTES=10
JITTER_MAX_MINUTES=15

# ── Поведение ────────────────────────────────────────────────────────────────
# Снимать ли режим "Не беспокоить" (убрать значок Zzz), когда мы активны: true/false
CLEAR_DND=false
# Что делать вне рабочих часов: "away" (явно серый) или "release" (отпустить, авто-режим Slack)
OFF_HOURS_MODE=release
# Интервал отправки ping в WebSocket, мс (держит соединение и сигналит активность)
PING_INTERVAL_MS=20000
# Как часто подтверждать presence=auto через Web API, мс
PRESENCE_REFRESH_MS=120000

# ── Мониторинг входящих сообщений (упоминания/DM) ────────────────────────────
# URL, на который POST'ить JSON при упоминании/DM. Пусто — уведомления только в лог.
WEBHOOK_URL=
# Уведомлять о прямых @-упоминаниях: true/false
NOTIFY_MENTIONS=true
# Уведомлять о любых личных сообщениях (DM): true/false
NOTIFY_DM=true

# ── Healthcheck (мониторинг протухания токена) ───────────────────────────────
# Порт HTTP-эндпоинта /health (его опрашивает Docker HEALTHCHECK)
HEALTH_PORT=3000
# Как часто проверять валидность токена через auth.test, мс
HEALTH_CHECK_MS=300000

# Уровень логов: debug | info | warn | error
LOG_LEVEL=info
