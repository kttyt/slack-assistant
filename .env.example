# Эти переменные настраивают все НЕсекретные параметры. Альтернатива/дополнение: config.yaml,
# передаётся через --config=config.yaml (см. config.example.yaml). Приоритет: ENV -> YAML -> дефолт
# (переменная окружения перекрывает значение из YAML).
# Секреты (SLACK_XOXC_TOKEN / SLACK_XOXD_COOKIE) задаются ТОЛЬКО здесь, в YAML их не кладут.

# ── Авторизация Slack (сессия веб-клиента) ───────────────────────────────────
# Как получить — см. README.md (раздел "Получение токенов").
# Токен веб-клиента, начинается с "xoxc-"
SLACK_XOXC_TOKEN=xoxc-...
# Значение cookie "d", начинается с "xoxd-"
SLACK_XOXD_COOKIE=xoxd-...
# База Slack Web API. Менять не нужно — переопределяется только в тестах (фейковый сервер).
# SLACK_API_BASE=https://slack.com/api

# ── Расписание рабочих часов ─────────────────────────────────────────────────
# Таймзона (IANA), в которой считаются рабочие часы
TZ=Europe/Moscow
# Дни недели, когда держим зелёный: 1=пн ... 7=вс. Диапазоны и списки: "1-5" или "1,2,3,4,5"
WORK_DAYS=1-5
# Начало и конец рабочего окна в формате HH:MM (по TZ выше)
WORK_START=09:00
WORK_END=19:00
# Плавающее расписание: границы старта/конца каждый день случайно сдвигаются на
# модуль jitterMin..jitterMax минут (знак тоже случаен). Сдвиг детерминирован по дню
# (стабилен в течение суток, меняется день ото дня). 0/0 — выключить плавание.
JITTER_MIN_MINUTES=10
JITTER_MAX_MINUTES=15

# ── Поведение ────────────────────────────────────────────────────────────────
# Снимать ли режим "Не беспокоить" (убрать значок Zzz), когда мы активны: true/false
CLEAR_DND=false
# Что делать вне рабочих часов: "away" (явно серый) или "release" (отпустить, авто-режим Slack)
OFF_HOURS_MODE=release
# Интервал отправки ping в WebSocket, мс (держит соединение и сигналит активность)
PING_INTERVAL_MS=20000
# Сколько ждать pong, прежде чем счесть соединение мёртвым и переподключиться, мс.
# Должен быть заметно больше PING_INTERVAL_MS (иначе ошибка валидации при старте).
PONG_TIMEOUT_MS=60000
# Как часто подтверждать presence=auto через Web API, мс
PRESENCE_REFRESH_MS=120000

# ── Мониторинг входящих сообщений (упоминания/DM/ключевые слова) ─────────────
# URL, на который POST'ить JSON при упоминании/DM. Пусто — уведомления только в лог.
WEBHOOK_URL=
# Уведомлять о прямых @-упоминаниях: true/false
NOTIFY_MENTIONS=true
# Считать @here/@channel/@everyone упоминанием: true/false
NOTIFY_CHANNEL_WIDE=false
# Уведомлять о личных сообщениях (1:1): true/false
NOTIFY_DM=true
# Префиксы id каналов, считающихся DM (через запятую). Обычно D
DM_CHANNEL_PREFIXES=D
# Уведомлять о групповых DM (mpim): true/false
NOTIFY_GROUP_DM=false
# Ключевые слова через запятую (без учёта регистра). Пусто — выключено
NOTIFY_KEYWORDS=
# Уведомлять о собственных сообщениях (обычно false; true — для самопроверки)
NOTIFY_SELF=false

# ── User-Agent ───────────────────────────────────────────────────────────────
# UA для Web API и WebSocket. Пусто — реалистичный браузерный дефолт.
# tools/grab-token.js может записать сюда настоящий UA вашего браузера.
USER_AGENT=

# ── HTTP/S-прокси (опционально) ──────────────────────────────────────────────
# Работает только с установленными пакетами: npm install undici https-proxy-agent
# Если задано, а пакетов нет — сервис завершится с понятной ошибкой при старте.
HTTP_PROXY=
HTTPS_PROXY=
# Хосты в обход прокси (через запятую); "*" — всё напрямую
NO_PROXY=

# ── HTTP API ─────────────────────────────────────────────────────────────────
# Порт HTTP-сервера (/health и /react). /health опрашивает Docker HEALTHCHECK
API_PORT=3000

# ── Healthcheck (мониторинг протухания токена) ───────────────────────────────
# Как часто проверять валидность токена через auth.test, мс
HEALTH_CHECK_MS=300000

# ── Управляющий API: реакция на сообщение ────────────────────────────────────
# Секрет для POST /react/{channel}/{ts} (тот же порт, что /health). Пусто — маршрут ВЫКЛЮЧЕН.
# Заголовок запроса: Authorization: Bearer <token>  (или X-Control-Token: <token>).
# Тело: {"reactionEmoji": ":eyes:"}. Только через окружение (это секрет).
# channel и ts видны в INFO-логе при уведомлении (ch=… ts=…).
CONTROL_TOKEN=

# Уровень логов: debug | info | warn | error
LOG_LEVEL=info
