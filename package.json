{
  "name": "slack-keep-active",
  "version": "1.0.0",
  "description": "Держит ваш Slack-аккаунт в статусе 'active' (зелёный шарик) по расписанию рабочих часов",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "grab-token": "node tools/grab-token.js",
    "lint": "eslint src test tools eslint.config.js vitest.config.js",
    "lint:fix": "eslint src test tools eslint.config.js vitest.config.js --fix",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "vitest": "^3.2.6"
  },
  "license": "MIT",
  "optionalDependencies": {
    "https-proxy-agent": "^9.1.0",
    "undici": "^8.6.0"
  }
}
